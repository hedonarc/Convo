# Development Settings
DEBUG=True

# Security (Required for all environments)
# Generate a new key for production and never share it!
SECRET_KEY=your-secret-key-here

# Database Configuration (Optional for local, defaults to sqlite)
# DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Host Configuration
# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://testserver

# Profiling
# Set to True to enable django-silk profiler
SILKY_PYTHON_PROFILER=False
